  {"id":"a1c7_16","q":"Tu ___ (se doucher - passé composé) ?","a":"t'es douché","choices":["t'as douché","te suis douché","t'est douché"],"tag":"Passé Composé (Pronominaux)","hint":"Auxiliaire ÊTRE à la 2e personne","expl":"Tu T'ES DOUCHÉ. / TE HAS DUCHADO."},
  {"id":"a1c7_17","q":"Ils ___ (se dépêcher - passé composé).","a":"se sont dépêchés","choices":["se ont dépêchés","nous sommes dépêchés","se sont dépêché"],"tag":"Passé Composé (Pronominaux)","hint":"Ils + se + sont + participe -s","expl":"Ils SE SONT DÉPÊCHÉS. / SE HAN DADO PRISA."}
