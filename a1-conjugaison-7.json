  {"id":"a1c7_08","q":"Vous ___ (choisir) quel dessert ?","a":"choisissez","choices":["choisis","choisissons","choisissent"],"tag":"Verbes -IR (2e)","hint":"Comme 'finir', radical en -iss-","expl":"CHOISIR : vous CHOISISSEZ. / ¿Qué postre ELIGEN?"},
  {"id":"a1c7_09","q":"Je ___ (choisir) ce livre.","a":"choisis","choices":["choisi","choisit","choisissons"],"tag":"Verbes -IR (2e)","hint":"Singulier : finit par -s","expl":"CHOISIR : je CHOISIS. / ELIJO ce livre."},
  {"id":"a1c7_10","q":"Ils ___ (finir) leur repas.","a":"finissent","choices":["finis","finissons","finissez"],"tag":"Verbes -IR (2e)","hint":"3ème personne du pluriel","expl":"FINIR : ils FINISSENT. / ELLOS TERMINAN."},
  {"id":"a1c7_11","q":"Je ___ (venir) de Paris.","a":"viens","choices":["vient","venons","venez"],"tag":"Venir","hint":"je/tu : finit par -s","expl":"VENIR : je viens, tu viens, il vient, nous venons, vous venez, ils viennent. / VENGO."},
  {"id":"a1c7_12","q":"Ils ___ (venir) à la fête ce soir.","a":"viennent","choices":["venons","venez","vient"],"tag":"Venir","hint":"Le 'n' double au pluriel","expl":"VENIR : ils VIENNENT. Ne pas confondre avec 'ils vont'. / ELLOS VIENEN."},
  {"id":"a1c7_13","q":"Je ___ (se lever - passé composé) à 7h ce matin.","a":"me suis levé","choices":["ai levé","m'ai levé","me suis levée"],"tag":"Passé Composé (Pronominaux)","hint":"Utilise l'auxiliaire ÊTRE","expl":"Verbes pronominaux : PRONOM + ÊTRE + PARTICIPE. Je ME SUIS LEVÉ. / ME HE LEVANTADO."},
